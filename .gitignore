# Ignore markdown files generated by tools.
# Keep only the project README files we want to track.
*.md
**/*.md
!README.md
!README_ZH.md
!api/README.md
!ui/README.md
!docker/README.md

# Local Codex / browser artifacts
.codex
.playwright-mcp/

# Local runtime secrets - 环境变量文件（包含敏感信息）
# 只保留项目根目录的 .env 文件
.env
!.env.example

# 旧的 .env 文件（已废弃，如果存在也忽略）
api/.env
docker/.env

# SSL 证书文件（绝对不能上传！）
docker/nginx/ssl/*.crt
docker/nginx/ssl/*.key
docker/nginx/ssl/*.pem
docker/ssl/*.crt
docker/ssl/*.key
docker/ssl/*.pem
*.crt
*.key
*.pem
!*.crt.example
!*.key.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/
.hypothesis/
*.cover
*.log

# IDE
.idea/
.vscode/
.VSCodeCounter/
.claude/
.worktrees/
*.swp
*.swo
*~
.DS_Store

# Docker
docker/volumes/
*.tar.gz

# Temporary files
tmp/
temp/
*.tmp
storage/
api/internal/core/vector_store/index.faiss
api/internal/core/vector_store/index.pkl

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/
