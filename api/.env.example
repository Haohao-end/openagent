# Cohere服务商配置
COHERE_API_KEY=

# 高德API
GAODE_API_KEY=

# 谷歌serper搜索
SERPER_API_KEY=

# WEAVIATE_HOST
WEAVIATE_HTTP_HOST=
WEAVIATE_HTTP_PORT=
WEAVIATE_GRPC_HOST=
WEAVIATE_GRPC_PORT=
WEAVIATE_API_KEY=

# GitHub OAuth应用密钥
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# Google OAuth应用秘钥
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# 腾讯云COS对象存储
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=
COS_BUCKET=
COS_DOMAIN=

# 腾讯云Serverless云函数SCF的SANDBOX_URL
