ZHIPUAI_API_BASE=

# LangSmith配置
LANGCHAIN_TRACING_V2=
LANGCHAIN_ENDPOINT=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

# （使用正斜杠，避免转义问题）
