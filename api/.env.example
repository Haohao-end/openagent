# ==================== Flask 基础配置 ====================
FLASK_DEBUG=0
FLASK_ENV=production

# ==================== WTF 配置 ====================
WTF_CSRF_ENABLED=False

# ==================== 服务配置 ====================
SERVICE_IP=your-server-ip
SERVICE_API_PREFIX=https://your-domain.com/api

# ==================== 前端构建配置 ====================
# UI 容器构建时注入的 API 前缀
VITE_API_PREFIX=http://127.0.0.1:5001

# ==================== JWT 加密密钥 ====================
# 生成方法: openssl rand -hex 32
JWT_SECRET_KEY=your-random-secret-key-here-change-this

# ==================== SQLAlchemy 数据库配置 ====================
# 本地开发使用 localhost，Docker 环境会自动覆盖为 llmops-db
SQLALCHEMY_DATABASE_URI=postgresql://postgres:your-password@localhost:5432/llmops?client_encoding=utf8
SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=True

# Docker 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=llmops

# ==================== 辅助 Agent 智能体应用 ID ====================
ASSISTANT_AGENT_ID=your-assistant-agent-id

# ==================== Redis 配置 ====================
# 本地开发使用 localhost，Docker 环境会自动覆盖为 llmops-redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0
REDIS_USE_SSL=False

# ==================== Celery 配置 ====================
CELERY_BROKER_DB=1
CELERY_RESULT_BACKEND_DB=1
CELERY_TASK_IGNORE_RESULT=False
CELERY_RESULT_EXPIRES=3600
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True

# ==================== Weaviate 向量数据库配置 ====================
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=your-weaviate-api-key

# Weaviate 用户配置（Docker 需要）
AUTHENTICATION_APIKEY_ALLOWED_KEYS=your-weaviate-api-key
AUTHENTICATION_APIKEY_USERS=admin@localhost
AUTHORIZATION_ADMINLIST_USERS=admin@localhost

# ==================== LLM API Keys ====================
# 月之暗面
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# 硅基流动
SILICONFLOW_API_BASE=https://api.siliconflow.cn
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Grok
GROK_API_KEY=sk-your-grok-key-here
GROK_API_BASE=https://api.x.ai/v1

# 百度千帆
qianfan_ak=your-qianfan-ak-here
qianfan_sk=your-qianfan-sk-here

# 通义千问
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 文心一言
WENXIN_YIYAN_API_KEY=your-wenxin-key-here

# ==================== LangSmith 配置 ====================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=YourProjectName

# ==================== 第三方服务 API Keys ====================
# Pinecone
PINECONE_API_KEY=your-pinecone-key-here

# HuggingFace
HUGGINGFACEHUB_API_TOKEN=your-huggingface-token-here
TRANSFORMERS_OFFLINE=0

# Cohere
COHERE_API_KEY=your-cohere-key-here

# 高德地图
GAODE_API_KEY=your-gaode-key-here

# 谷歌 Serper 搜索
SERPER_API_KEY=your-serper-key-here

# SerpAPI
SERPAPI_API_KEY=your-serpapi-key-here

# Tavily AI
TAVILY_API_KEY=your-tavily-key-here

# ==================== 插件 API Keys ====================
# Stability AI (图像生成)
STABILITY_API_KEY=sk-your-stability-key-here

# OpenWeatherMap (天气)
OPENWEATHERMAP_API_KEY=your-openweathermap-key-here

# News API (新闻)
NEWSAPI_API_KEY=your-newsapi-key-here

# Wolfram Alpha (计算)
WOLFRAM_ALPHA_APPID=your-wolfram-appid-here

# GitHub (代码)
GITHUB_ACCESS_TOKEN=ghp_your-github-token-here

# ==================== OAuth 配置 ====================
# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5173/auth/authorize/github

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/authorize/google

# ==================== 腾讯云 COS 对象存储 ====================
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-beijing
COS_SCHEME=https
COS_BUCKET=your-bucket-name
COS_DOMAIN=https://your-bucket-name.cos.ap-beijing.myqcloud.com
COS_TIMEOUT_SECONDS=10
COS_SDK_RETRY=1
COS_UPLOAD_MAX_ATTEMPTS=3
COS_AUTO_SWITCH_DOMAIN_ON_RETRY=True
COS_ENABLE_OLD_DOMAIN=True
COS_ENABLE_INTERNAL_DOMAIN=False

# 腾讯云 Serverless 云函数
SANDBOX_URL=https://your-scf-url.tencentscf.com

# ==================== 邮件服务配置 ====================
# QQ 邮箱 SMTP 配置（用于发送验证码）
MAIL_SERVER=smtp.qq.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=your-email@qq.com

# ==================== Nginx 配置 ====================
NGINX_DOMAIN_NAME=localhost
NGINX_SSL_CERT_FILE=server.crt
NGINX_SSL_KEY_FILE=server.key
NGINX_ENABLE_HTTPS=false

# ==================== Docker 端口配置 ====================
UI_PORT=3000
API_PORT=5001
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
POSTGRES_PORT=5432
WEAVIATE_GRPC_PORT=50051

# ==================== 镜像版本 ====================
IMAGE_VERSION=0.1.0

# VITE_TITLE 浏览器网站标题
VITE_TITLE=OpenAgent

# OAuth 允许的来源域名（用于动态回调地址）
OAUTH_ALLOWED_ORIGINS=https://openllm.cloud
