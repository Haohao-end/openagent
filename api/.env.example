# ==================== LLMOps 统一配置文件 ====================
# 此文件包含所有配置，避免配置分散

# ==================== 域名和 SSL 配置 ====================
# 生产环境域名
NGINX_DOMAIN_NAME=localhost

# SSL 证书文件名（放在 docker/nginx/ssl/ 目录）
NGINX_SSL_CERT_FILE=server.crt
NGINX_SSL_KEY_FILE=server.key

# 是否启用 HTTPS（生产环境: true, 本地开发: false）
NGINX_ENABLE_HTTPS=false

# ==================== Flask 基础配置 ====================
FLASK_DEBUG=0
FLASK_ENV=production

# ==================== 服务配置 ====================
SERVICE_IP=82.157.66.198
SERVICE_API_PREFIX=http://82.157.66.198/api

# ==================== JWT 加密密钥 ====================
# 生成方法: openssl rand -hex 32
JWT_SECRET_KEY=your-random-secret-key-here-change-this

# ==================== 数据库配置 ====================
# 本地开发使用 localhost，Docker 环境会自动覆盖为 llmops-db
SQLALCHEMY_DATABASE_URI=postgresql://postgres:your-password@localhost:5432/llmops?client_encoding=utf8
SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_ECHO=True

# Docker 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=llmops

# ==================== Redis 配置 ====================
# 本地开发使用 localhost，Docker 环境会自动覆盖为 llmops-redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0
REDIS_USE_SSL=False

# ==================== Weaviate 配置 ====================
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=ftBC9hKkjfdbdi0W3T6kEtMh5BZFpGa1DF8
AUTHENTICATION_APIKEY_ALLOWED_KEYS=ftBC9hKkjfdbdi0W3T6kEtMh5BZFpGa1DF8
AUTHENTICATION_APIKEY_USERS=admin@localhost
AUTHORIZATION_ADMINLIST_USERS=admin@localhost

# ==================== Celery 配置 ====================
CELERY_BROKER_DB=1
CELERY_RESULT_BACKEND_DB=1
CELERY_TASK_IGNORE_RESULT=False
CELERY_RESULT_EXPIRES=3600
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=True

# ==================== 辅助 Agent ====================
ASSISTANT_AGENT_ID=6774fcef-b594-8008-b30c-a05b8190afe6

# ==================== LLM API Keys ====================
# 月之暗面
MOONSHOT_API_KEY=sk-your-api-key-here

