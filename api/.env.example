# Flask基础配置
FLASK_DEBUG=
FLASK_ENV=

# 容器运行参数
SERVER_WORKER_AMOUNT=
SERVER_THREAD_AMOUNT=
CELERY_WORKER_AMOUNT=
HF_ENDPOINT=

# wtf配置
WTF_CSRF_ENABLED=

# CORS配置（生产环境请设置为前端域名，逗号分隔）
CORS_ALLOW_ORIGINS=
CORS_SUPPORTS_CREDENTIALS=

# OAuth 动态回调白名单（留空表示仅使用固定 GITHUB/GOOGLE_REDIRECT_URI）
OAUTH_ALLOWED_ORIGINS=

# WebApp 访客 Cookie 安全配置
WEB_APP_VISITOR_COOKIE_SECURE=
WEB_APP_VISITOR_COOKIE_SECRET=

# 服务配置
SERVICE_IP=
SERVICE_API_PREFIX=

# jwt加密密钥
JWT_SECRET_KEY=

# SQLAlchemy数据库配置
SQLALCHEMY_DATABASE_URI=
SQLALCHEMY_POOL_SIZE=
SQLALCHEMY_POOL_RECYCLE=
SQLALCHEMY_ECHO=

# 辅助Agent智能体应用id标识
ASSISTANT_AGENT_ID=

# Redis数据库配置
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=
REDIS_USE_SSL=

# Celery配置
CELERY_BROKER_DB=
CELERY_RESULT_BACKEND_DB=
CELERY_TASK_IGNORE_RESULT=
CELERY_RESULT_EXPIRES=
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=

# 月之暗面服务提供者
MOONSHOT_API_KEY=

# 硅基流动
SILICONFLOW_API_BASE=
SILICONFLOW_API_KEY=

# DeepSeek API 配置
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=

# OpenAI model
OPENAI_API_KEY=
OPENAI_API_BASE=

# Anthropic Claude服务提供者（可选）
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=

# Claude服务提供者
CLAUDE_API_KEY=
CLAUDE_API_BASE=

# Grok服务提供者
GROK_API_KEY=
GROK_API_BASE=

# 百度千帆服务提供者
qianfan_ak=
qianfan_sk=

