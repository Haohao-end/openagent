# SerpAPI多搜索引擎 https://serpapi.com
SERPAPI_API_KEY=

# Tavily AI优化搜索 https://tavily.com
TAVILY_API_KEY=

# 图像生成插件
# Stability AI (Stable Diffusion) https://platform.stability.ai
STABILITY_API_KEY=

# 天气插件
# OpenWeatherMap全球天气 https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# 新闻插件
# News API全球新闻 https://newsapi.org
NEWSAPI_API_KEY=

# 计算插件
# Wolfram Alpha计算引擎 https://products.wolframalpha.com/api
WOLFRAM_ALPHA_APPID=

# 代码插件（可选）
# GitHub仓库搜索 https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=

# 邮件服务配置（用于发送验证码）
# QQ邮箱SMTP配置
MAIL_SERVER=
MAIL_PORT=
MAIL_USE_TLS=
MAIL_USE_SSL=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Docker compose基础设施变量（供docker/docker-compose.yaml插值）
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# 容器运行模式（Docker 专用，本地开发无需配置）
# 可选值: api, celery
MODE=

# 数据库迁移开关（Docker 专用，本地开发无需配置）
# 可选值: true, false
MIGRATION_ENABLED=
