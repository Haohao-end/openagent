# --- 1. 敏感文件与证书 (Security & Credentials) ---
# 保护你的 API 密钥和证书不被索引
.env
.env.*
*.pem
cacert.pem
*.key
*.crt

# --- 2. 持久化存储与数据 (Storage & Data) ---
# 忽略本地上传的文件、模型缓存和向量数据库索引
storage/
/api/storage/
/api/data/
*.db
*.sqlite3

# --- 3. 临时文件与缓存 (Temp & Cache) ---
tmp/
temp/
.pytest_cache/
.ruff_cache/
.mypy_cache/
__pycache__/
*.pyc
.cache/

# --- 4. 容器与构建 (Docker & Build) ---
# 忽略 Docker 构建时的中间产物
.dockerignore
Dockerfile
docker/
dist/
bin/

# --- 5. 依赖管理 (Dependencies) ---
# 依赖文件通常很大，且 AI 只需要读取 requirements.txt 即可，不需要索引整个环境
.venv/
venv/
node_modules/
vendor/

# --- 6. 测试与日志 (Testing & Logs) ---
test/
tests/
*.log
coverage.xml
.coverage
pytest.ini

# --- 7. 系统与 IDE (System & IDE) ---
.DS_Store
.vscode/
.idea/
.cursor/