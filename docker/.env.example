# ==================== Docker Compose 基础设施配置 ====================

# PostgreSQL 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=llmops123456
POSTGRES_DB=llmops

# Redis 密码
REDIS_PASSWORD=llmops123456

# Weaviate API Key
WEAVIATE_API_KEY=ftBC9hKkjfdbdi0W3T6kEtMh5BZFpGa1DF8
WEAVIATE_USER=2227625024@qq.com

# ==================== 端口映射配置 ====================
UI_PORT=3000
API_PORT=5001
REDIS_PORT=6379
POSTGRES_PORT=5432
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==================== 域名和 SSL 配置 ====================
# 域名配置（必须修改为你的实际域名）
DOMAIN_NAME=openllm.cloud

# SSL 证书路径（相对于 docker/ssl/ 目录）
# 注意：SSL 证书文件不会上传到 Git，需要手动上传到服务器
SSL_CERT_FILE=openllm.cloud_bundle.crt
SSL_KEY_FILE=openllm.cloud.key

# 是否启用 HTTPS（true/false）
ENABLE_HTTPS=true

# ==================== 镜像版本 ====================
IMAGE_VERSION=0.1.0

# ==================== 说明 ====================
# 1. DOMAIN_NAME: 你的域名，用于 Nginx server_name
# 2. SSL_CERT_FILE: SSL 证书文件名（放在 docker/ssl/ 目录下）
# 3. SSL_KEY_FILE: SSL 私钥文件名（放在 docker/ssl/ 目录下）
# 4. ENABLE_HTTPS: 是否启用 HTTPS（生产环境设为 true，本地开发设为 false）
# 5. SSL 证书文件需要手动上传到服务器的 docker/ssl/ 目录
